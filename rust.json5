{
  cargo: {
    rangeStrategy: "update-lockfile",
  },
  packageRules: [
    // --- Group non-major Cargo updates into one PR ---
    {
      matchManagers: ["cargo"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "rust crates (non-major)",
      addLabels: ["patch"],
    },
    // --- Major bumps get individual PRs ---
    {
      matchManagers: ["cargo"],
      matchUpdateTypes: ["major"],
      addLabels: ["minor"],
    },
    // --- Auto-merge lockfile maintenance (no version semantics changed) ---
    {
      matchManagers: ["cargo"],
      matchUpdateTypes: ["lockFileMaintenance"],
      automerge: true,
      addLabels: ["patch"],
    },
  ],
}
