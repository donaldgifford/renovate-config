{
  terraform: {
    pinDigests: true,
  },
  packageRules: [
    // --- Group non-major provider updates (terraform + terragrunt) ---
    {
      matchManagers: ["terraform", "terragrunt"],
      matchDepTypes: ["provider"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "terraform providers (non-major)",
      addLabels: ["patch"],
    },
    // --- Group non-major module updates ---
    {
      matchManagers: ["terraform", "terragrunt"],
      matchDepTypes: ["module"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "terraform modules (non-major)",
      addLabels: ["patch"],
    },
    // --- Major bumps get individual PRs ---
    {
      matchManagers: ["terraform", "terragrunt"],
      matchUpdateTypes: ["major"],
      addLabels: ["minor"],
    },
    // --- Auto-merge lockfile maintenance for .terraform.lock.hcl ---
    {
      matchManagers: ["terraform"],
      matchUpdateTypes: ["lockFileMaintenance"],
      automerge: true,
      addLabels: ["patch"],
    },
  ],
}
