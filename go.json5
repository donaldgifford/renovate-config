{
  "gomod": {
    "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"]
  },
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "go modules (non-major)",
      "addLabels": ["patch"]
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["minor"]
    }
  ]
}
