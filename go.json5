{
  gomod: {
    postUpdateOptions: ["gomodTidy", "gomodUpdateImportPaths"],
  },
  packageRules: [
    // --- Group non-major Go module updates into one PR ---
    {
      matchManagers: ["gomod"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "go modules (non-major)",
      addLabels: ["patch"],
    },
    // --- Major bumps get individual PRs ---
    {
      matchManagers: ["gomod"],
      matchUpdateTypes: ["major"],
      addLabels: ["minor"],
    },
    // --- Label Go toolchain/version bumps as minor ---
    {
      matchDepNames: ["go"],
      matchManagers: ["gomod"],
      addLabels: ["minor"],
    },
    // --- Go tooling config files: label as dont-release ---
    {
      matchFileNames: [".goreleaser.yml", ".golangci.yml"],
      addLabels: ["dont-release"],
    },
  ],
}
