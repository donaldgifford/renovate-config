{
  dockerfile: {
    pinDigests: true,
  },
  packageRules: [
    // --- Group non-major docker-bake variable updates (custom regex) ---
    {
      matchManagers: ["custom.regex"],
      matchFileNames: ["**/docker-bake.hcl"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "docker-bake variables (non-major)",
      addLabels: ["patch", "dont-release"],
    },
    // --- Major docker-bake bumps get individual PRs ---
    {
      matchManagers: ["custom.regex"],
      matchFileNames: ["**/docker-bake.hcl"],
      matchUpdateTypes: ["major"],
      addLabels: ["minor"],
    },
  ],
  customManagers: [
    // --- Track version variables in docker-bake.hcl ---
    // Annotate variables with a renovate comment:
    //   # renovate: image=golang
    //   variable "GO_IMAGE_TAG" { default = "1.23.2-bookworm" }
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)docker-bake\\.hcl$/"],
      matchStrings: [
        '#\\s*renovate:\\s*image=(?<depName>[^\\s]+)\\nvariable\\s+"[^"]+"\\s*\\{\\s*default\\s*=\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: "docker",
      versioningTemplate: "docker",
    },
  ],
}
