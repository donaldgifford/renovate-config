{
  packageRules: [
    // --- Kustomize image updates: label as dont-release ---
    {
      matchManagers: ["kustomize"],
      addLabels: ["dont-release"],
    },
    // --- Group non-major kustomize image bumps ---
    {
      matchManagers: ["kustomize"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "kustomize images (non-major)",
      addLabels: ["patch"],
    },
    // --- Major bumps get individual PRs ---
    {
      matchManagers: ["kustomize"],
      matchUpdateTypes: ["major"],
      addLabels: ["minor"],
    },
  ],
}
