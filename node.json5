{
  npm: {
    rangeStrategy: "update-lockfile",
    postUpdateOptions: ["yarnDedupeHighest"],
  },
  packageRules: [
    // --- Group non-major dependency updates ---
    {
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "node packages (non-major)",
      addLabels: ["patch"],
    },
    // --- Major bumps get individual PRs ---
    {
      matchManagers: ["npm"],
      matchUpdateTypes: ["major"],
      addLabels: ["minor"],
    },
    // --- Auto-merge @types/* non-major (no runtime impact) ---
    {
      matchManagers: ["npm"],
      matchPackageNames: ["@types/**"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "type definitions",
      addLabels: ["patch"],
      automerge: true,
    },
    // --- Label Node.js / bun runtime bumps as minor ---
    {
      matchDepNames: ["node", "bun"],
      matchManagers: ["nodenv", "nvm", "npm"],
      addLabels: ["minor"],
    },
  ],
}
