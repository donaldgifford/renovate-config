{
  // Base labels applied to every Renovate PR
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    // --- Go dependencies → patch ---
    {
      "matchManagers": [
        "gomod"
      ],
      "addLabels": [
        "patch"
      ]
    },
    // --- CI / GitHub Actions → dont-release ---
    {
      "matchManagers": [
        "github-actions"
      ],
      "addLabels": [
        "dont-release"
      ]
    },
    // --- Dockerfiles → dont-release ---
    {
      "matchManagers": [
        "dockerfile"
      ],
      "addLabels": [
        "dont-release"
      ]
    },
    // --- Any non-code config file (broader catch-all) ---
    {
      "matchFileNames": [
        ".github/**",
        ".goreleaser.yml",
        "Makefile",
        ".golangci.yml"
      ],
      "addLabels": [
        "dont-release"
      ]
    },
    // --- Go major bumps → minor instead of patch ---
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "minor"
      ],
      // Remove the default "patch" label for majors
      "labels": [
        "dependencies",
        "minor"
      ]
    },
    // --- Security fixes → always release ---
    {
      "matchManagers": [
        "gomod"
      ],
      "vulnerabilityAlerts": true,
      "labels": [
        "dependencies",
        "patch",
        "security"
      ]
    }
  ]
}
