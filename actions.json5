{
  "packageRules": [
    // --- Pin GitHub Actions to digests for reproducibility ---
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    // --- Group non-major Actions updates ---
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github actions (non-major)",
      "addLabels": ["patch"]
    },
    // --- Major Actions bumps get individual PRs ---
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["minor"]
    }
  ]
}
